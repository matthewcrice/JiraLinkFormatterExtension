{
  "manifest_version": 3,
  "name": "Jira Link Formatter",
  "version": "1.0.0",
  "description": "Copies Jira issue links as formatted text: 'PROJ-123: Issue Title' with hyperlink.",
  "permissions": [
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.atlassian.net/*",
    "*://jira.unity3d.com/*",
    "*://*/browse/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.atlassian.net/*",
        "*://jira.unity3d.com/*",
        "*://*/browse/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
